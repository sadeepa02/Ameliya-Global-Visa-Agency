generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(cuid())
  email String @unique
  role  String @default("user")
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String
  createdAt   DateTime @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  email     String
  mobile    String
  visaType  String
  date      DateTime
  status    String   @default("pending")
  createdAt DateTime @default(now())
}
